rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
    }
    match /teams/{doc} {
      allow write: if request.auth != null;
    }
    match /players/{doc} {
      allow write: if request.auth != null;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingPhotoUrl', 'photoStatus']);
    }
    match /matches/{doc} {
      allow write: if request.auth != null;
    }
    match /matches/{matchId}/events/{eventId} {
      allow write: if request.auth != null;
    }
    match /matches/{matchId}/playerStints/{stintId} {
      allow write: if request.auth != null;
    }
    match /seasons/{doc} {
      allow write: if request.auth != null;
    }
    match /courts/{doc} {
      allow write: if request.auth != null;
    }
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /auditLog/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    match /posts/{doc} {
      allow write: if request.auth != null;
    }
    match /updates/{doc} {
      allow write: if request.auth != null;
    }
    match /config/{doc} {
      allow write: if request.auth != null;
    }
  }
}
